<!DOCTYPE html>

<html>
<head>
  <title><%= title %></title>
  <meta http-equiv="content-type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" media="all" href="<%= css %>" />
</head>
<body>
  <div id="container">
    <div id="background"></div>
    <div id="layout_toggles">
      <span class="label">Code:</span>
      <a href="javascript:setLayout('side')" id="toggle_side" class="active">Right</a>
      <a href="javascript:setLayout('top')" id="toggle_top">Below</a>
      <a href="javascript:setLayout('bottom')" id="toggle_bottom">Above</a>
    </div>
    <% if (sources.length > 1) { %>
      <ul id="jump_to">
        <li>
          <a href="javascript:void(0);" onclick="toggleJumpTo(event)">Jump To &hellip;</a>
          <div id="jump_wrapper">
          <div id="jump_page">
            <% for (var i=0, l=sources.length; i<l; i++) { %>
              <% var source = sources[i]; %>
              <a class="source" href="<%= relative(destination(source)) %>">
                <%= path.basename(source) %>
              </a>
            <% } %>
          </div>
        </li>
      </ul>
    <% } %>
    <ul class="sections">
        <% if (!hasTitle) { %>
          <li id="title">
              <div class="annotation">
                  <h1><%= title %></h1>
              </div>
          </li>
        <% } %>
        <% for (var i=0, l=sections.length; i<l; i++) { %>
        <% var section = sections[i]; %>
        <li id="section-<%= i + 1 %>">
            <div class="annotation">
              <% heading = section.docsHtml.match(/^\s*<(h\d)>/) %>
              <div class="sswrap <%= heading ? 'for-' + heading[1] : '' %>">
                <a class="ss" href="#section-<%= i + 1 %>">&#x00a7;</a>
              </div>
              <%= section.docsHtml %>
            </div>
            <% if (section.codeText.replace(/\s/gm, '') != '') { %>
            <div class="content"><%= section.codeHtml %></div>
            <% } %>
        </li>
        <% } %>
    </ul>
  </div>
  <script>
    function setLayout(layout) {
      document.body.className = 'layout-' + layout;
      localStorage.setItem('docPageLayout', layout);
      
      document.getElementById('toggle_side').className = layout === 'side' ? 'active' : '';
      document.getElementById('toggle_top').className = layout === 'top' ? 'active' : '';
      document.getElementById('toggle_bottom').className = layout === 'bottom' ? 'active' : '';
      
      var viewport = document.querySelector('meta[name="viewport"]');
      if (layout === 'side') {
        viewport.setAttribute('content', 'width=1200, user-scalable=yes');
      } else {
        viewport.setAttribute('content', 'width=device-width, initial-scale=1.0');
      }
    }

    function toggleJumpTo(e) {
      e.stopPropagation();
      var jumpTo = document.getElementById('jump_to');
      if (jumpTo) jumpTo.classList.toggle('active');
    }

    window.addEventListener('click', function(e) {
      var jumpTo = document.getElementById('jump_to');
      if (jumpTo && !jumpTo.contains(e.target)) {
        jumpTo.classList.remove('active');
      }
    });
    
    // Initialize
    var savedLayout = localStorage.getItem('docPageLayout');
    if (!savedLayout) {
      if (window.innerWidth < 600 || window.screen.width < 600) {
        savedLayout = 'bottom';
      } else {
        savedLayout = 'side';
      }
    }
    setLayout(savedLayout);
  </script>
</body>
</html>
